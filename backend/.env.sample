# Serveur
PORT=3000
FRONTEND_URL=http://localhost:0000
# URL publique du backend, utilisée pour construire les URLs de retour du
# flow Steam OpenID (site web) - doit matcher le domaine enregistré côté Steam
BACKEND_URL=http://localhost:3000

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=wyrdane_game
# true requis contre un MySQL managé (ex. Aiven) qui exige TLS
DB_SSL=false

# JWT : doit être une longue chaîne aléatoire en production
TOKEN_SECRET=change_me_in_production

# Steam Web API (partner.steamgames.com) : sert à vérifier les tickets de
# session envoyés par le client Godot (et par le site web via Steam OpenID)
STEAM_WEB_API_KEY=change_me
STEAM_APP_ID=480

# Dev uniquement : débloque toute la collection de cartes à la création d'un
# compte, pour tester le deck builder sans passer par les vrais déblocages
DEV_GRANT_ALL_CARDS=false

# Dev uniquement : active POST /api/packs/open-free (ouverture de pack sans
# débit), pour tester l'écran d'ouverture sans farmer de la monnaie
DEV_FREE_PACKS=false

# Dev uniquement : accepte un ticket "DEV:<steamid>" sans vérification Steam
# réelle (AuthenticateUserTicket exige une clé Publisher, indisponible tant
# qu'on n'a pas d'accès Steamworks Partner). Ne JAMAIS activer en production.
DEV_SKIP_STEAM_VERIFY=false